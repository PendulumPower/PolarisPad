{
    "keyboard_name": "polarispad",
    "manufacturer": "Par Gunderson",
    "maintainer": "PendulumPower",

    "usb": {
        "vid": "0x504C",
        "pid": "0x5041",
        "device_version": "1.0.0"
    },
    
    "processor": "RP2040",
    "bootloader": "rp2040",

    "features": {
        "bootmagic": false,
        "mousekey": true,
        "extrakey": true,
        "encoder": false,
        "oled": false,
        "rgb_matrix": false
    },

    "matrix_pins": {
        "rows": ["GP8", "GP9"],
        "cols": ["GP2", "GP4", "GP10", "GP11"]
    },

    "diode_direction": "COL2ROW",

    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0,0], "x":0, "y":0},
                {"matrix": [0,1], "x":1, "y":0},
                {"matrix": [0,2], "x":2, "y":0},
                {"matrix": [0,3], "x":3, "y":0},

                {"matrix": [1,0], "x":0, "y":1},
                {"matrix": [1,1], "x":1, "y":1},
                {"matrix": [1,2], "x":2, "y":1},
                {"matrix": [1,3], "x":3, "y":1}
            ]
        }
    }
}